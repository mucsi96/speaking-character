# ElevenLabs configuration for the TTS proxy (server-side only).
# Copy to .env for local development: cp .env.example .env

# Required: your ElevenLabs API key.
ELEVENLABS_API_KEY=

# Required: the voice id to speak with (pick a German-capable voice).
ELEVENLABS_VOICE_ID=

# Optional: model. eleven_multilingual_v2 = highest quality German.
# eleven_flash_v2_5 = lower latency alternative.
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Optional: HTTP port (default 3000).
PORT=3000

# Optional: where to cache generated MP3s (default ./cache).
CACHE_DIR=./cache
